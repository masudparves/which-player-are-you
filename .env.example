# ─────────────────────────────────────────────────────────────
# OPTIONAL: Firebase (for REAL shared visitor counters)
# The site works perfectly WITHOUT this — it falls back to the
# browser's local counter automatically. Only fill this in when
# you want a global, shared "visitors" number.
#
# How to get these values: see README.md → "Add Firebase later".
# Copy this file to a new file named  .env   and fill in the values.
# ─────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
